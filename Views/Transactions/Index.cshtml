@model IEnumerable<FinanceManager2._0.Models.Transaction>
@{
    string sortBy = ViewBag.SortBy ?? "date";
    string sortOrder = ViewBag.SortOrder ?? "desc";
    string toggleOrder(string field) => (sortBy == field && sortOrder == "asc") ? "desc" : "asc";
}

<h2>💰 Транзакції</h2>

<a asp-action="Create" class="btn btn-success mb-3">➕ Додати транзакцію</a>
<a asp-controller="Recurring" asp-action="Index" class="btn btn-info mb-3">🔄 Планові платежі</a>
<a asp-controller="Statistics" asp-action="Compare" class="btn btn-primary mb-3">📊 Порівняння витрат</a>

<!-- 🔹 Форма пошуку -->
<form method="get" class="mb-3 row g-2">
    <div class="col-auto">
        <input type="text" name="searchKeyword" value="@ViewBag.SearchKeyword" class="form-control" placeholder="Пошук нотатки..." />
    </div>
    <div class="col-auto">
        <input type="number" step="0.01" name="minAmount" value="@ViewBag.MinAmount" class="form-control" placeholder="Мін сума" />
    </div>
    <div class="col-auto">
        <input type="number" step="0.01" name="maxAmount" value="@ViewBag.MaxAmount" class="form-control" placeholder="Макс сума" />
    </div>
    <div class="col-auto">
        <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control" />
    </div>
    <div class="col-auto">
        <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control" />
    </div>
    <div class="col-auto">
        <select name="categoryId" class="form-select">
            <option value="0">Всі категорії</option>
            @foreach (var c in (SelectList)ViewData["CategoryId"])
            {
                bool isSelected = ViewBag.SelectedCategoryId != null && ViewBag.SelectedCategoryId == int.Parse(c.Value);
                <option value="@c.Value" selected="@(isSelected ? "selected" : null)">@c.Text</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">🔍 Фільтрувати</button>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortBy="category" asp-route-sortOrder="@toggleOrder("category")">Категорія</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortBy="date" asp-route-sortOrder="@toggleOrder("date")">Дата</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortBy="amount" asp-route-sortOrder="@toggleOrder("amount")">Сума</a>
            </th>
            <th>Нотатка</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var t in Model)
            {
                <tr>
                    <td>@t.Category?.Name</td>
                    <td>@t.Date.ToLocalTime().ToShortDateString()</td>
                    <td style="color:@(t.Amount < 0 ? "red" : "green")">@t.Amount</td>
                    <td>@t.Note</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-warning btn-sm">✏</a>
                        <form asp-action="DeleteConfirmed" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@t.Id" />
                            <button class="btn btn-danger btn-sm" onclick="return confirm('Видалити транзакцію?')">🗑</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="5" class="text-muted">Транзакцій ще немає.</td></tr>
        }
    </tbody>
</table>

@if (ViewBag.RecurringPayments != null && ViewBag.RecurringPayments.Count > 0)
{
    <h4>🔄 Активні планові платежі</h4>
    <ul>
        @foreach (var r in ViewBag.RecurringPayments)
        {
            <li>@r.Name: @r.Amount (@r.Category?.Name) - Початок: @r.StartDate.ToLocalTime().ToShortDateString()</li>
        }
    </ul>
}
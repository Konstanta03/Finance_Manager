@using FinanceManager2._0.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager
@inject FinanceDbContext DbContext

@{
    var currentUser = User.Identity?.IsAuthenticated == true ? await UserManager.GetUserAsync(User) : null;
    var settings = currentUser != null ? await DbContext.Settings.AsNoTracking().FirstOrDefaultAsync(s => s.UserId == currentUser.Id) : null;
    var themeClass = settings?.Theme == "dark" ? "theme-dark" : "theme-light";
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Finance Manager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="@themeClass">
    <header>
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">💰 Finance Manager</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="nav">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">🏠 Home</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Transactions" asp-action="Index">💰 Транзакції</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Recurring" asp-action="Index">🗓 Планувальник</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Categories" asp-action="Index">📂 Категорії</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Settings" asp-action="Index">⚙️ Налаштування</a></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="User" asp-action="Index">👑 Admin</a></li>
                            }
                            <li class="nav-item"><a class="nav-link text-danger" asp-controller="User" asp-action="Logout">🚪 Вийти</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="User" asp-action="Login">🔐 Вхід</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="User" asp-action="Register">📝 Реєстрація</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="toast-success">@TempData["Success"]</div>
    }

    @if (TempData["Warning"] != null)
    {
        <div class="toast-warning">@TempData["Warning"]</div>
    }

    <div class="container app-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-center">
        <div class="container">
            <span>© 2026 - Finance Manager | ASP.NET Core + Identity + PostgreSQL</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

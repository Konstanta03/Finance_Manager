@model IEnumerable<FinanceManager2._0.Models.Category>

<h2>Категорії</h2>

<a asp-action="Create" class="btn btn-success mb-3">➕ Додати</a>

@if (Model != null && Model.Any())
{
    @foreach (var item in Model)
    {
        <div class="card-custom d-flex justify-content-between align-items-center">

            <div>
                <h5>@item.Name</h5>
                <small class="text-muted">
                    @(item.IsExpense ? "Витрати 💸" : "Дохід 💰")
                </small>
            </div>

            <div>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">✏</a>

                <form asp-action="DeleteConfirmed" method="post" style="display:inline;">
                    <input type="hidden" name="id" value="@item.Id" />

                    <button class="btn btn-danger btn-sm"
                            onclick="return confirm('Точно видалити категорію?')">
                        🗑
                    </button>
                </form>
            </div>

        </div>
    }
}
else
{
    <p>Категорій немає</p>
}
@model FinanceManager2._0.Models.Settings

@{
    ViewData["Title"] = "Налаштування";
}

<div class="theme-panel">
    <h2>⚙️ Налаштування</h2>
    <p class="text-muted">Тут можна змінити валюту, мову та тему інтерфейсу.</p>

    <form asp-action="Index" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="UserId" />

        <div class="mb-3">
            <label asp-for="Currency" class="form-label">Валюта</label>
            <select asp-for="Currency" class="form-control">
                <option value="UAH">UAH — гривня</option>
                <option value="USD">USD — долар</option>
                <option value="EUR">EUR — євро</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="Language" class="form-label">Мова</label>
            <select asp-for="Language" class="form-control">
                <option value="uk">Українська</option>
                <option value="en">English</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="Theme" class="form-label">Тема</label>
            <select asp-for="Theme" class="form-control">
                <option value="light">Світла</option>
                <option value="dark">Темна</option>
            </select>
            <div class="form-text">Після збереження сторінка оновиться з вибраною темою.</div>
        </div>

        <div class="mb-3 form-check">
            <input asp-for="SaveSettings" class="form-check-input" type="checkbox" />
            <label asp-for="SaveSettings" class="form-check-label">Автозбереження налаштувань</label>
        </div>

        <div class="mb-3">
            <label asp-for="ExportData" class="form-label">Експорт даних</label>
            <select asp-for="ExportData" class="form-control">
                <option value="CSV">CSV</option>
                <option value="JSON">JSON</option>
            </select>
        </div>

        <button type="submit" class="btn btn-success">💾 Зберегти</button>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary ms-2">⬅️ На головну</a>
    </form>
</div>

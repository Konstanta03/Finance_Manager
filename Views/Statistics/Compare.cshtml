@model FinanceManager2._0.Models.CompareExpensesViewModel
@{
    ViewData["Title"] = "Порівняння витрат";
}
<h2>📊 Порівняльна статистика витрат</h2>
<p class="text-muted">Порівняння витрат за різні періоди.</p>
<form method="get" class="card-custom mb-4">
    <div class="row g-3">
        <div class="col-md-3"><label class="form-label">Поточний період з</label><input type="date" name="currentStart" value="@ViewBag.CurrentStart" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">Поточний період до</label><input type="date" name="currentEnd" value="@ViewBag.CurrentEnd" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">Попередній період з</label><input type="date" name="previousStart" value="@ViewBag.PreviousStart" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">Попередній період до</label><input type="date" name="previousEnd" value="@ViewBag.PreviousEnd" class="form-control" /></div>
    </div>
    <button type="submit" class="btn btn-primary mt-3">🔍 Порівняти</button>
</form>
<div class="row mb-3">
    <div class="col-md-4"><div class="card-custom"><h5>Поточний період</h5><strong>@Model.CurrentPeriodTotal</strong></div></div>
    <div class="col-md-4"><div class="card-custom"><h5>Попередній період</h5><strong>@Model.PreviousPeriodTotal</strong></div></div>
    <div class="col-md-4"><div class="card-custom"><h5>Зміна</h5><strong>@Model.ChangePercent.ToString("F2") %</strong></div></div>
</div>
<canvas id="expensesChart" width="400" height="160"></canvas>
<table class="table table-sm table-striped mt-3">
    <thead><tr><th>Категорія</th><th>Поточний період</th><th>Попередній період</th><th>Зміна (%)</th></tr></thead>
    <tbody>
        @if (Model.ExpensesByCategory.Any())
        {
            foreach (var c in Model.ExpensesByCategory)
            {
                var change = c.PreviousAmount == 0 ? 100 : Math.Round((c.CurrentAmount - c.PreviousAmount) / c.PreviousAmount * 100, 2);
                <tr><td>@c.CategoryName</td><td>@c.CurrentAmount</td><td>@c.PreviousAmount</td><td>@change.ToString("F2") %</td></tr>
            }
        }
        else { <tr><td colspan="4" class="text-muted">Немає даних для порівняння.</td></tr> }
    </tbody>
</table>
@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const ctx = document.getElementById('expensesChart').getContext('2d');
const labels = [@Html.Raw(string.Join(",", Model.ExpensesByCategory.Select(c => "'" + c.CategoryName.Replace("'", "\\'") + "'")))];
const currentData = [@string.Join(",", Model.ExpensesByCategory.Select(c => c.CurrentAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)))];
const previousData = [@string.Join(",", Model.ExpensesByCategory.Select(c => c.PreviousAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)))];
new Chart(ctx, { type: 'bar', data: { labels: labels, datasets: [{ label: 'Поточний період', data: currentData }, { label: 'Попередній період', data: previousData }] }, options: { responsive: true, scales: { y: { beginAtZero: true } } } });
</script>
}
